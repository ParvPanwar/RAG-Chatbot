APP_NAME=Social Video Comparison API
APP_ENV=development
OLLAMA_BASE_URL=https://your-ollama-server.example.com
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_API_KEY=
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
INSTAGRAM_COOKIE_FILE=
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_TIMEOUT_SECONDS=90
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=video_transcripts_local
RAG_TOP_K=6
MAX_CHUNKS_PER_VIDEO=120
